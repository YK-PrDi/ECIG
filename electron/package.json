{
  "name": "ai-studio",
  "version": "1.2.0",
  "description": "AI 产品图片生成系统",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.elebusiness.aistudio",
    "productName": "AI Studio",
    "copyright": "ELE Business",
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico",
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI Studio",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "extraResources": [
      { "from": "../dist/app.jar",  "to": "app.jar"  },
      { "from": "../dist/runtime",  "to": "runtime"  },
      { "from": "../dist/frontend", "to": "frontend" },
      { "from": "../prompts",       "to": "prompts"  }
    ],
    "directories": {
      "output": "../dist-electron"
    }
  }
}
